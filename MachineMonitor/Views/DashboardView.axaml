<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MachineMonitor.ViewModels"
             x:Class="MachineMonitor.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="#0F1923">

    <UserControl.Styles>

        <Style Selector="Border.metric-card">
            <Setter Property="Background" Value="#111D2C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="BorderBrush" Value="#1E2D40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="110"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="Border.status-card">
            <Setter Property="Background" Value="#111D2C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#1E2D40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="86"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="TextBlock.card-label">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="LetterSpacing" Value="0.8"/>
        </Style>

        <Style Selector="TextBlock.card-value">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="LineHeight" Value="36"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,4,20,0"/>
        </Style>

        <Style Selector="TextBlock.card-unit">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="4,0,0,4"/>
        </Style>

        <!-- Control buttons base -->
        <Style Selector="Button.ctrl">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.ctrl:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>

        <!-- Green: ligar -->
        <Style Selector="Button.ctrl-green">
            <Setter Property="Background" Value="#102A1A"/>
            <Setter Property="Foreground" Value="#00C853"/>
        </Style>
        <Style Selector="Button.ctrl-green:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#17381F"/>
        </Style>

        <!-- Red: desligar -->
        <Style Selector="Button.ctrl-red">
            <Setter Property="Background" Value="#2A0E14"/>
            <Setter Property="Foreground" Value="#FF5252"/>
        </Style>
        <Style Selector="Button.ctrl-red:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#391219"/>
        </Style>

        <!-- Yellow: alarme -->
        <Style Selector="Button.ctrl-yellow">
            <Setter Property="Background" Value="#2A2208"/>
            <Setter Property="Foreground" Value="#FFB800"/>
        </Style>
        <Style Selector="Button.ctrl-yellow:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#39300A"/>
        </Style>

        <!-- Blue: setpoints -->
        <Style Selector="Button.ctrl-blue">
            <Setter Property="Background" Value="#082236"/>
            <Setter Property="Foreground" Value="#00B4D8"/>
        </Style>
        <Style Selector="Button.ctrl-blue:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0A2E48"/>
        </Style>

        <!-- TextBox for setpoint inputs -->
        <Style Selector="TextBox.setpoint">
            <Setter Property="Background" Value="#0D1522"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#1E2D40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00B4D8"/>
        </Style>
        <Style Selector="TextBox.setpoint:focus">
            <Setter Property="BorderBrush" Value="#00B4D8"/>
        </Style>

    </UserControl.Styles>

    <!--
        ScrollViewer evita corte em janelas pequenas.
        StackPanel + Auto height impede o esticamento vertical dos cards.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22,20,22,22" Spacing="14">

            <!-- Timestamp bar -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="7" Height="7" Fill="#00C853" VerticalAlignment="Center"/>
                    <TextBlock Text="AO VIVO"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#00C853"
                               LetterSpacing="1"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Atualizado às"
                               FontSize="11" Foreground="#2D3748"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastUpdate}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#4A5568"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- ── 4 Metric cards ── -->
            <Grid ColumnDefinitions="*,12,*,12,*,12,*">

                <!-- Temperature -->
                <Border Classes="metric-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TEMPERATURA" Classes="card-label"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Temperature, StringFormat='{}{0:F1}'}"
                                       Classes="card-value"/>
                            <TextBlock Text="°C" Classes="card-unit"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding Temperature}"
                                     Minimum="0" Maximum="120"
                                     Height="3"
                                     Foreground="#FF6B35"
                                     Background="#1A2D42"/>
                    </StackPanel>
                </Border>

                <!-- Pressure -->
                <Border Grid.Column="2" Classes="metric-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="PRESSÃO" Classes="card-label"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Pressure, StringFormat='{}{0:F2}'}"
                                       Classes="card-value"/>
                            <TextBlock Text="bar" Classes="card-unit"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding Pressure}"
                                     Minimum="0" Maximum="10"
                                     Height="3"
                                     Foreground="#00B4D8"
                                     Background="#1A2D42"/>
                    </StackPanel>
                </Border>

                <!-- Motor Speed -->
                <Border Grid.Column="4" Classes="metric-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="VELOCIDADE" Classes="card-label"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding MotorSpeed, StringFormat='{}{0:F0}'}"
                                       Classes="card-value"/>
                            <TextBlock Text="rpm" Classes="card-unit"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding MotorSpeed}"
                                     Minimum="0" Maximum="2000"
                                     Height="3"
                                     Foreground="#7B2FBE"
                                     Background="#1A2D42"/>
                    </StackPanel>
                </Border>

                <!-- Production -->
                <Border Grid.Column="6" Classes="metric-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="PRODUÇÃO" Classes="card-label"/>
                        <TextBlock Text="{Binding ProductionCount}"
                                   Classes="card-value"
                                   Foreground="#FFC107"/>
                        <TextBlock Text="peças contadas"
                                   FontSize="10"
                                   Foreground="#2D3748"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- ── 2 Status cards ── -->
            <Grid ColumnDefinitions="*,12,*">

                <!-- Machine status -->
                <Border Classes="status-card">
                    <Grid ColumnDefinitions="5,*">
                        <Border Grid.Column="0"
                                Background="{Binding MachineOnColor}"
                                CornerRadius="10,0,0,10"/>
                        <Border Grid.Column="1" Padding="18,16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="STATUS DA MÁQUINA" Classes="card-label"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Ellipse Width="12" Height="12"
                                             Fill="{Binding MachineOnColor}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding MachineOnLabel}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{Binding MachineOnColor}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Alarm status -->
                <Border Grid.Column="2" Classes="status-card">
                    <Grid ColumnDefinitions="5,*">
                        <Border Grid.Column="0"
                                Background="{Binding AlarmColor}"
                                CornerRadius="10,0,0,10"/>
                        <Border Grid.Column="1" Padding="18,16">
                            <StackPanel Spacing="6">

                                <!-- Label + ícone de informação -->
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <TextBlock Text="STATUS DE ALARME" Classes="card-label"/>
                                    <Border Width="15" Height="15" CornerRadius="8"
                                            Background="#1E3A5F"
                                            VerticalAlignment="Center"
                                            Cursor="Hand">
                                        <ToolTip.Tip>
                                            <StackPanel Spacing="8" MaxWidth="290">
                                                <TextBlock Text="Condições de Alarme"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="#E2E8F0"/>
                                                <Border Height="1" Background="#2D3748"/>
                                                <StackPanel Spacing="5">
                                                    <TextBlock FontSize="11" Foreground="#CBD5E0"
                                                               Text="• Temp &gt; 95 °C — Superaquecimento"/>
                                                    <TextBlock FontSize="11" Foreground="#CBD5E0"
                                                               Text="• Pressão &gt; 7,0 bar — Sobrepressão"/>
                                                    <TextBlock FontSize="11" Foreground="#CBD5E0"
                                                               Text="• Pressão &lt; 1,0 bar — Baixa pressão"/>
                                                    <TextBlock FontSize="11" Foreground="#CBD5E0"
                                                               Text="• Motor ligado e vel. &lt; 200 rpm — Falha de partida"/>
                                                </StackPanel>
                                                <Border Height="1" Background="#2D3748"/>
                                                <TextBlock FontSize="10" Foreground="#4A5568"
                                                           TextWrapping="Wrap"
                                                           Text="O alarme permanece ativo até ser resetado manualmente pelo operador."/>
                                            </StackPanel>
                                        </ToolTip.Tip>
                                        <TextBlock Text="i"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="#00B4D8"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <!-- Status + razão -->
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Ellipse Width="12" Height="12"
                                             Fill="{Binding AlarmColor}"
                                             VerticalAlignment="Top"
                                             Margin="0,5,0,0"/>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding AlarmLabel}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding AlarmColor}"/>
                                        <TextBlock Text="{Binding AlarmReason}"
                                                   FontSize="11"
                                                   Foreground="#FF9999"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="220"
                                                   IsVisible="{Binding AlarmActive}"/>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

            </Grid>

            <!-- ── Controles da máquina ── -->
            <Border Background="#111D2C"
                    CornerRadius="10"
                    BorderBrush="#1E2D40"
                    BorderThickness="1"
                    Padding="18,16"
                    ClipToBounds="True">
                <StackPanel Spacing="14">

                    <!-- Header -->
                    <TextBlock Text="CONTROLES DA MÁQUINA"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#4A5568" LetterSpacing="0.8"/>

                    <!-- Machine + alarm buttons -->
                    <Grid ColumnDefinitions="*,10,*,10,*">
                        <Button Classes="ctrl ctrl-green"
                                Content="Ligar Máquina"
                                Command="{Binding TurnOnMachineCommand}"/>
                        <Button Grid.Column="2"
                                Classes="ctrl ctrl-red"
                                Content="Desligar Máquina"
                                Command="{Binding TurnOffMachineCommand}"/>
                        <Button Grid.Column="4"
                                Classes="ctrl ctrl-yellow"
                                Content="Resetar Alarme"
                                Command="{Binding ResetAlarmCommand}"/>
                    </Grid>

                    <!-- Setpoints + send -->
                    <Grid ColumnDefinitions="*,10,*,10,Auto">

                        <StackPanel Spacing="5">
                            <TextBlock Text="SETPOINT TEMP. (°C)"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#4A5568" LetterSpacing="0.8"/>
                            <TextBox Classes="setpoint"
                                     Text="{Binding TemperatureSetpointInput}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="5">
                            <TextBlock Text="SETPOINT MOTOR (rpm)"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#4A5568" LetterSpacing="0.8"/>
                            <TextBox Classes="setpoint"
                                     Text="{Binding MotorSpeedSetpointInput}"/>
                        </StackPanel>

                        <Button Grid.Column="4"
                                Classes="ctrl ctrl-blue"
                                Content="Enviar Setpoints"
                                Command="{Binding SendSetpointsCommand}"
                                VerticalAlignment="Bottom"
                                Padding="14,9"/>

                    </Grid>

                    <!-- Feedback message -->
                    <TextBlock Text="{Binding CommandMessage}"
                               Foreground="{Binding CommandMessageColor}"
                               FontSize="12" FontWeight="SemiBold"
                               IsVisible="{Binding HasCommandMessage}"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
