<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MachineMonitor.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="MachineMonitor.Views.TrendsView"
             x:DataType="vm:TrendsViewModel"
             Background="#0F1923">

    <UserControl.Styles>
        <Style Selector="Border.chart-card">
            <Setter Property="Background" Value="#111D2C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#1E2D40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22,20,22,22" Spacing="14">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="7" Height="7" Fill="#00C853" VerticalAlignment="Center"/>
                    <TextBlock Text="AO VIVO — últimos 60 segundos"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#00C853" LetterSpacing="1"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Dados atualizados a cada 1 s"
                           FontSize="10" Foreground="#2D3748"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Temperatura -->
            <Border Classes="chart-card">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FF6B35" VerticalAlignment="Center"/>
                        <TextBlock Text="TEMPERATURA (°C)"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#FF6B35" LetterSpacing="0.8"/>
                    </StackPanel>
                    <lvc:CartesianChart Height="140"
                                        Series="{Binding TempSeries}"
                                        YAxes="{Binding TempYAxes}"
                                        XAxes="{Binding XAxes}"
                                        Background="Transparent"
                                        AnimationsSpeed="00:00:00.200"/>
                </StackPanel>
            </Border>

            <!-- Pressão -->
            <Border Classes="chart-card">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#00B4D8" VerticalAlignment="Center"/>
                        <TextBlock Text="PRESSÃO (bar)"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#00B4D8" LetterSpacing="0.8"/>
                    </StackPanel>
                    <lvc:CartesianChart Height="140"
                                        Series="{Binding PressSeries}"
                                        YAxes="{Binding PressYAxes}"
                                        XAxes="{Binding XAxes}"
                                        Background="Transparent"
                                        AnimationsSpeed="00:00:00.200"/>
                </StackPanel>
            </Border>

            <!-- Velocidade do motor -->
            <Border Classes="chart-card">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#7B2FBE" VerticalAlignment="Center"/>
                        <TextBlock Text="VELOCIDADE DO MOTOR (rpm)"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#7B2FBE" LetterSpacing="0.8"/>
                    </StackPanel>
                    <lvc:CartesianChart Height="140"
                                        Series="{Binding MotorSeries}"
                                        YAxes="{Binding MotorYAxes}"
                                        XAxes="{Binding XAxes}"
                                        Background="Transparent"
                                        AnimationsSpeed="00:00:00.200"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
